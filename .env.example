# Floxy residential proxy gateway credentials.
# From a floxy proxy string like:
#   9c907f4ce24b:edf151bc6330_session-9dwtkgh0_lifetime-1200@residential.floxy.io:12321
# the pieces are:
#   FLOXY_USER = 9c907f4ce24b
#   FLOXY_PASS = edf151bc6330    (base password, WITHOUT the _session-... suffix)
#   FLOXY_HOST = residential.floxy.io
#   FLOXY_PORT = 12321
FLOXY_HOST=residential.floxy.io
FLOXY_PORT=12321
FLOXY_USER=your-floxy-user
FLOXY_PASS=your-floxy-pass

# How long (seconds) each sticky session holds the same exit IP. Floxy appends
# this to the password as _lifetime-<N>. 1200s (20 min) is floxy's default.
FLOXY_SESSION_LIFETIME=1200
